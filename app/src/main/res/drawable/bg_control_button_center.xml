<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/button_shell" />
            <corners android:radius="28dp" />
            <stroke
                android:width="2dp"
                android:color="@color/button_outer_outline" />
        </shape>
    </item>

    <item
        android:left="5dp"
        android:top="5dp"
        android:right="5dp"
        android:bottom="5dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/button_fill_top"
                android:endColor="@color/button_fill_bottom" />
            <corners android:radius="23dp" />
            <stroke
                android:width="1dp"
                android:color="@color/button_inner_outline" />
        </shape>
    </item>
</layer-list>
