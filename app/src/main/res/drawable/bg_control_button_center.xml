<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_shell_pressed_top"
                        android:endColor="@color/control_center_shell_pressed_bottom" />
                    <stroke android:width="2.4dp" android:color="@color/control_center_shell_stroke_pressed" />
                </shape>
            </item>
            <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_ring_back_pressed_top"
                        android:endColor="@color/control_center_ring_back_pressed_bottom" />
                    <stroke android:width="8dp" android:color="@color/control_center_ring_pressed" />
                </shape>
            </item>
            <item android:left="13dp" android:top="13dp" android:right="13dp" android:bottom="13dp">
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_inner_pressed_top"
                        android:endColor="@color/control_center_inner_pressed_bottom" />
                    <stroke android:width="1.8dp" android:color="@color/control_center_inner_stroke_pressed" />
                </shape>
            </item>
            <item android:left="19dp" android:top="20dp" android:right="19dp" android:bottom="66dp">
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_highlight_pressed"
                        android:endColor="@android:color/transparent" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_shell_top"
                        android:endColor="@color/control_center_shell_bottom" />
                    <stroke android:width="2.4dp" android:color="@color/control_center_shell_stroke" />
                </shape>
            </item>
            <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_ring_back_top"
                        android:endColor="@color/control_center_ring_back_bottom" />
                    <stroke android:width="8dp" android:color="@color/control_center_ring" />
                </shape>
            </item>
            <item android:left="13dp" android:top="13dp" android:right="13dp" android:bottom="13dp">
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_inner_top"
                        android:endColor="@color/control_center_inner_bottom" />
                    <stroke android:width="1.8dp" android:color="@color/control_center_inner_stroke" />
                </shape>
            </item>
            <item android:left="19dp" android:top="20dp" android:right="19dp" android:bottom="66dp">
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_highlight"
                        android:endColor="@android:color/transparent" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
