                </shape>
            </item>
            <item android:top="17dp" android:bottom="17dp" android:left="17dp" android:right="17dp">
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:endColor="#122231"
                        android:startColor="#4A647F" />
                    <stroke android:width="1.6dp" android:color="#7B96B1" />
                </shape>
            </item>
            <item android:top="20dp" android:bottom="68dp" android:left="25dp" android:right="25dp">
                <shape android:shape="oval">
                    <gradient android:angle="270" android:startColor="#8FC9E6FF" android:endColor="#00C9E6FF" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
