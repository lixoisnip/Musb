<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="@color/control_pressed" />
            <stroke android:width="2dp" android:color="@color/accent_amber" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:endColor="#1A1F26"
                android:startColor="@color/control_bg" />
            <stroke android:width="2dp" android:color="@color/accent_amber_soft" />
        </shape>
    </item>
</selector>
