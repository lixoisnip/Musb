<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <gradient android:angle="270" android:startColor="#142637" android:endColor="#02050A" />
                    <stroke android:width="1.2dp" android:color="#2C455C" />
                </shape>
            </item>
            <item android:top="3dp" android:bottom="3dp" android:left="3dp" android:right="3dp">
                <shape android:shape="oval">
                    <gradient android:angle="270" android:startColor="#213447" android:endColor="#0A131C" />
                    <stroke android:width="6dp" android:color="#E7A456" />
                </shape>
            </item>
            <item android:top="11dp" android:bottom="11dp" android:left="11dp" android:right="11dp">
                <shape android:shape="oval">
                    <stroke android:width="1.2dp" android:color="#335069" />
