                        android:endColor="#101F2D"
                        android:startColor="#435D78" />
                    <stroke android:width="1.6dp" android:color="#7390AA" />
                </shape>
            </item>
            <item android:top="20dp" android:bottom="68dp" android:left="25dp" android:right="25dp">
                <shape android:shape="oval">
                    <gradient android:angle="270" android:startColor="#96D0EDFF" android:endColor="#00D0EDFF" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
