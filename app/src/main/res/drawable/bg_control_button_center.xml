<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <gradient android:angle="270" android:startColor="#69411F" android:endColor="#4C2F17" />
            <stroke android:width="3dp" android:color="@color/accent_amber" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient android:angle="270" android:startColor="#3A414B" android:endColor="#222831" />
            <stroke android:width="3dp" android:color="@color/accent_amber_soft" />
        </shape>
    </item>
</selector>
