<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_shell_disabled_top"
                        android:endColor="@color/control_center_shell_disabled_bottom" />
                    <stroke android:width="2dp" android:color="@color/control_center_shell_stroke_disabled" />
                </shape>
            </item>
            <item android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp">
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_ring_back_disabled_top"
                        android:endColor="@color/control_center_ring_back_disabled_bottom" />
                    <stroke android:width="6dp" android:color="@color/control_center_ring_disabled" />
                </shape>
            </item>
            <item android:left="16dp" android:top="16dp" android:right="16dp" android:bottom="16dp">
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_inner_disabled_top"
                        android:endColor="@color/control_center_inner_disabled_bottom" />
                    <stroke android:width="1dp" android:color="@color/control_center_inner_stroke_disabled" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_shell_pressed_top"
                        android:endColor="@color/control_center_shell_pressed_bottom" />
                    <stroke android:width="2dp" android:color="@color/control_center_shell_stroke_pressed" />
                </shape>
            </item>
            <item android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp">
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_ring_back_pressed_top"
                        android:endColor="@color/control_center_ring_back_pressed_bottom" />
                    <stroke android:width="6dp" android:color="@color/control_center_ring_pressed" />
                </shape>
            </item>
            <item android:left="16dp" android:top="16dp" android:right="16dp" android:bottom="16dp">
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_inner_pressed_top"
                        android:endColor="@color/control_center_inner_pressed_bottom" />
                    <stroke android:width="1dp" android:color="@color/control_center_inner_stroke_pressed" />
                </shape>
            </item>
            <item android:left="42dp" android:top="18dp" android:right="42dp" android:bottom="122dp">
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_highlight_pressed"
                        android:endColor="@android:color/transparent" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_shell_top"
                        android:endColor="@color/control_center_shell_bottom" />
                    <stroke android:width="2dp" android:color="@color/control_center_shell_stroke" />
                </shape>
            </item>
            <item android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp">
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_ring_back_top"
                        android:endColor="@color/control_center_ring_back_bottom" />
                    <stroke android:width="6dp" android:color="@color/control_center_ring" />
                </shape>
            </item>
            <item android:left="16dp" android:top="16dp" android:right="16dp" android:bottom="16dp">
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_inner_top"
                        android:endColor="@color/control_center_inner_bottom" />
                    <stroke android:width="1dp" android:color="@color/control_center_inner_stroke" />
                </shape>
            </item>
            <item android:left="42dp" android:top="18dp" android:right="42dp" android:bottom="122dp">
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_center_highlight"
                        android:endColor="@android:color/transparent" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
