<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:gravity="top|center_horizontal" android:width="130dp" android:height="64dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:endColor="#070B11"
                android:startColor="#171C24" />
            <stroke android:width="1dp" android:color="#303843" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#04070C"
                android:startColor="#11151C" />
            <corners android:radius="22dp" />
            <stroke android:width="1dp" android:color="#2C333E" />
        </shape>
    </item>
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#070C13"
                android:startColor="#141B25" />
            <corners android:radius="21dp" />
            <stroke android:width="1dp" android:color="#1E2631" />
        </shape>
    </item>
    <item android:gravity="top|center_horizontal" android:width="116dp" android:height="58dp" android:top="3dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:endColor="#0B1119"
                android:startColor="#1A222D" />
            <stroke android:width="1dp" android:color="#222B37" />
        </shape>
    </item>
</layer-list>
