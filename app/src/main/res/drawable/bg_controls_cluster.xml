<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#070A0F"
                android:startColor="#11161E" />
        </shape>
    </item>

    <item android:top="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="1dp" android:color="#303844" />
        </shape>
    </item>

    <item android:gravity="top|center_horizontal"
        android:width="292dp"
        android:height="102dp"
        android:top="-26dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#4C171D27"
                android:endColor="#0011161E" />
        </shape>
    </item>

    <item android:gravity="top|center_horizontal"
        android:width="236dp"
        android:height="60dp"
        android:top="-8dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#2AA0783E"
                android:endColor="#00A0783E" />
        </shape>
    </item>
</layer-list>
