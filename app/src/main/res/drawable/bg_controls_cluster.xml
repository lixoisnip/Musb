<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#090C12"
                android:startColor="#12161D" />
        </shape>
    </item>
    <item android:gravity="top|center_horizontal" android:width="220dp" android:height="84dp" android:top="-22dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:endColor="#0012161D"
                android:startColor="#551C222C" />
        </shape>
    </item>
    <item android:top="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="1dp" android:color="#2D3440" />
        </shape>
    </item>
    <item android:gravity="top|center_horizontal" android:width="226dp" android:height="86dp" android:top="-16dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:endColor="#00000000"
                android:startColor="#2B12161D" />
        </shape>
    </item>
</layer-list>
