<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#181612"
                android:centerColor="#100E0B"
                android:endColor="#090806" />
        </shape>
    </item>

    <item android:top="1dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#3A352F" />
        </shape>
    </item>
</layer-list>
