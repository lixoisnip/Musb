<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/dock_top"
                android:centerColor="@color/dock_mid"
                android:endColor="@color/dock_bottom" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="@color/dock_border" />
        </shape>
    </item>

    <item android:top="1dp" android:bottom="126dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/dock_gloss_top"
                android:centerColor="@color/dock_gloss_mid"
                android:endColor="@color/dock_gloss_bottom" />
        </shape>
    </item>

    <item android:left="430dp" android:top="0dp" android:right="430dp" android:bottom="28dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="180dp"
                android:startColor="@color/dock_center_glow_warm"
                android:centerColor="@color/dock_center_glow_cool"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

    <item android:top="1dp" android:bottom="174dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="@color/dock_inner_border" />
        </shape>
    </item>
</layer-list>
