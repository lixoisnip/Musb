<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#1A1E24" android:endColor="#0C0F13" />
                    <corners android:radius="18dp" />
                    <stroke android:width="1.5dp" android:color="#58616D" />
                </shape>
            </item>
            <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#14181D" android:endColor="#090C10" />
                    <corners android:radius="17dp" />
                    <stroke android:width="1dp" android:color="#21262D" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#1A1E24" android:endColor="#0C0F13" />
                    <corners android:radius="18dp" />
                    <stroke android:width="1dp" android:color="#353B44" />
                </shape>
            </item>
            <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#14181D" android:endColor="#090C10" />
                    <corners android:radius="17dp" />
                    <stroke android:width="1dp" android:color="#21262D" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
