<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#28221B" android:endColor="#16120E" />
                    <corners android:radius="18dp" />
                    <stroke android:width="1.5dp" android:color="@color/accent_amber" />
                </shape>
            </item>
            <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#211B15" android:endColor="#13100C" />
                    <corners android:radius="17dp" />
                    <stroke android:width="1dp" android:color="#352D24" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#28221B" android:endColor="#16120E" />
                    <corners android:radius="18dp" />
                    <stroke android:width="1dp" android:color="#453B31" />
                </shape>
            </item>
            <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#211B15" android:endColor="#13100C" />
                    <corners android:radius="17dp" />
                    <stroke android:width="1dp" android:color="#2D261F" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
