<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#232323" android:endColor="#141414" />
                    <corners android:radius="18dp" />
                    <stroke android:width="1.5dp" android:color="@color/accent_amber" />
                </shape>
            </item>
            <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#1D1D1D" android:endColor="#121212" />
                    <corners android:radius="17dp" />
                    <stroke android:width="1dp" android:color="#2D2D2D" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#232323" android:endColor="#141414" />
                    <corners android:radius="18dp" />
                    <stroke android:width="1dp" android:color="#3A3A3A" />
                </shape>
            </item>
            <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#1D1D1D" android:endColor="#121212" />
                    <corners android:radius="17dp" />
                    <stroke android:width="1dp" android:color="#2A2A2A" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
