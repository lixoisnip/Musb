<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:startColor="@color/list_item_selected_top" android:endColor="@color/list_item_selected" />
            <corners android:radius="11dp" />
            <stroke android:width="1dp" android:color="@color/accent_amber" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:startColor="#262D36" android:endColor="#171C23" />
            <corners android:radius="11dp" />
            <stroke android:width="1dp" android:color="#2E3742" />
        </shape>
    </item>
</selector>
