<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#3A4756" android:endColor="#1A2430" />
                    <corners android:radius="10dp" />
                    <stroke android:width="1dp" android:color="#617287" />
                </shape>
            </item>
            <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="8dp" />
                    <stroke android:width="1dp" android:color="#243140" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_activated="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#8D5C2A" android:endColor="#392616" />
                    <corners android:radius="4dp" />
                    <stroke android:width="1dp" android:color="#59B47330" />
                </shape>
            </item>
            <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="0dp">
                <shape android:shape="rectangle">
                    <solid android:color="#00FFFFFF" />
                    <corners android:radius="4dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#303A46" android:endColor="#161F2A" />
                    <corners android:radius="10dp" />
                    <stroke android:width="1dp" android:color="#404E5F" />
                </shape>
            </item>
            <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="8dp" />
                    <stroke android:width="1dp" android:color="#202B39" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
