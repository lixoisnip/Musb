<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:startColor="#36414D" android:endColor="#1B232D" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="#586678" />
        </shape>
    </item>
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:startColor="@color/list_item_selected_top" android:endColor="@color/list_item_selected" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="@color/accent_amber" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:startColor="#2D3640" android:endColor="#171E27" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="#384352" />
        </shape>
    </item>
</selector>
