<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="@color/list_item_selected"
                android:startColor="@color/list_item_selected_top" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="@color/accent_amber_soft" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/list_item_bg" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="#2A313A" />
        </shape>
    </item>
</selector>
