            </item>
            <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="3dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_small_pressed_top"
                        android:endColor="@color/control_small_pressed_bottom" />
                    <corners android:radius="10dp" />
                    <stroke android:width="1.6dp" android:color="@color/control_small_stroke_pressed" />
                </shape>
            </item>
            <item android:left="5dp" android:top="5dp" android:right="5dp" android:bottom="24dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_small_highlight_pressed"
                        android:endColor="@android:color/transparent" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
            <item android:left="6dp" android:top="7dp" android:right="6dp" android:bottom="7dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_small_inner_pressed_top"
                        android:endColor="@color/control_small_inner_pressed_bottom" />
                    <corners android:radius="8dp" />
                    <stroke android:width="1dp" android:color="@color/control_small_inner_stroke" />
                </shape>
            </item>
        </layer-list>
    </item>

