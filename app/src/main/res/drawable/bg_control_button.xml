<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/control_disabled" />
            <corners android:radius="13dp" />
            <stroke android:width="1dp" android:color="#2D3440" />
        </shape>
    </item>
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:startColor="@color/control_active_top" android:endColor="@color/control_active_bottom" />
            <corners android:radius="13dp" />
            <stroke android:width="1dp" android:color="@color/accent_amber" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/control_pressed" />
            <corners android:radius="13dp" />
            <stroke android:width="1dp" android:color="@color/stroke_subtle" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="270" android:startColor="#313A45" android:endColor="#20262E" />
            <corners android:radius="13dp" />
            <stroke android:width="1dp" android:color="@color/stroke_subtle" />
        </shape>
    </item>
</selector>
