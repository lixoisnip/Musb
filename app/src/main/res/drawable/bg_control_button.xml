<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#0A1118" android:endColor="#04070B" />
                    <corners android:radius="13dp" />
                </shape>
            </item>
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_disabled_bottom"
                        android:startColor="@color/control_small_disabled_top" />
                    <corners android:radius="11dp" />
                    <stroke android:width="1dp" android:color="#394551" />
                </shape>
            </item>
            <item android:top="3dp" android:bottom="24dp" android:left="4dp" android:right="4dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#4C5B6D" android:endColor="#104C5B6D" />
                    <corners android:radius="9dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#0B141E" android:endColor="@color/control_small_shadow" />
                    <corners android:radius="13dp" />
                </shape>
            </item>
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_pressed_bottom"
                        android:startColor="@color/control_small_pressed_top" />
                    <corners android:radius="11dp" />
                    <stroke android:width="1.1dp" android:color="@color/control_small_stroke_active" />
                </shape>
            </item>
            <item android:top="3.5dp" android:bottom="23dp" android:left="4.5dp" android:right="4.5dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="@color/control_small_highlight" android:endColor="#105F7288" />
                    <corners android:radius="8.5dp" />
                </shape>
            </item>
            <item android:top="5dp" android:bottom="5dp" android:left="5dp" android:right="5dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#2A3644" android:endColor="#182330" />
                    <corners android:radius="9dp" />
                    <stroke android:width="0.9dp" android:color="@color/control_small_stroke_inner" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#0A121B" android:endColor="@color/control_small_shadow" />
                    <corners android:radius="13dp" />
                </shape>
            </item>
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_active_bottom"
                        android:startColor="@color/control_small_active_top" />
                    <corners android:radius="11dp" />
                    <stroke android:width="1.1dp" android:color="@color/control_small_stroke_active" />
                </shape>
            </item>
            <item android:top="3.5dp" android:bottom="23dp" android:left="4.5dp" android:right="4.5dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="@color/control_small_highlight" android:endColor="#105F7288" />
                    <corners android:radius="8.5dp" />
                </shape>
            </item>
            <item android:top="5dp" android:bottom="5dp" android:left="5dp" android:right="5dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#2E3D4D" android:endColor="#1A2835" />
                    <corners android:radius="9dp" />
                    <stroke android:width="0.9dp" android:color="@color/control_small_stroke_inner" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_activated="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#0A121B" android:endColor="@color/control_small_shadow" />
                    <corners android:radius="13dp" />
                </shape>
            </item>
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_active_bottom"
                        android:startColor="@color/control_small_active_top" />
                    <corners android:radius="11dp" />
                    <stroke android:width="1.1dp" android:color="@color/control_small_stroke_active" />
                </shape>
            </item>
            <item android:top="3.5dp" android:bottom="23dp" android:left="4.5dp" android:right="4.5dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="@color/control_small_highlight" android:endColor="#105F7288" />
                    <corners android:radius="8.5dp" />
                </shape>
            </item>
            <item android:top="5dp" android:bottom="5dp" android:left="5dp" android:right="5dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#2E3D4D" android:endColor="#1A2835" />
                    <corners android:radius="9dp" />
                    <stroke android:width="0.9dp" android:color="@color/control_small_stroke_inner" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#0A121B" android:endColor="@color/control_small_shadow" />
                    <corners android:radius="13dp" />
                </shape>
            </item>
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_bottom"
                        android:startColor="@color/control_small_top" />
                    <corners android:radius="11dp" />
                    <stroke android:width="1.1dp" android:color="@color/control_small_stroke" />
                </shape>
            </item>
            <item android:top="3.5dp" android:bottom="23dp" android:left="4.5dp" android:right="4.5dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="@color/control_small_highlight" android:endColor="#105F7288" />
                    <corners android:radius="8.5dp" />
                </shape>
            </item>
            <item android:top="5dp" android:bottom="5dp" android:left="5dp" android:right="5dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#293743" android:endColor="#172430" />
                    <corners android:radius="9dp" />
                    <stroke android:width="0.9dp" android:color="@color/control_small_stroke_inner" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
