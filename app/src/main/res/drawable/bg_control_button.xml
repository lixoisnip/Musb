<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#111C28" android:endColor="#04070A" />
                    <corners android:radius="14dp" />
                    <stroke android:width="1dp" android:color="#253344" />
                </shape>
            </item>
            <item android:top="3dp" android:bottom="3dp" android:left="3dp" android:right="3dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_disabled_bottom"
                        android:startColor="@color/control_small_disabled_top" />
                    <corners android:radius="10dp" />
                    <stroke android:width="1.2dp" android:color="#465667" />
                </shape>
            </item>
            <item android:top="4dp" android:bottom="22dp" android:left="5dp" android:right="5dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#6A7E95" android:endColor="#086A7E95" />
                    <corners android:radius="7.5dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#132130" android:endColor="#04070B" />
                    <corners android:radius="14dp" />
                    <stroke android:width="1dp" android:color="#33495E" />
                </shape>
            </item>
            <item android:top="3dp" android:bottom="3dp" android:left="3dp" android:right="3dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_pressed_bottom"
                        android:startColor="@color/control_small_pressed_top" />
                    <corners android:radius="10dp" />
                    <stroke android:width="1.4dp" android:color="#A9BCD2" />
                </shape>
            </item>
            <item android:top="4.5dp" android:bottom="21dp" android:left="5.5dp" android:right="5.5dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#8EA5BE" android:endColor="#128EA5BE" />
                    <corners android:radius="7dp" />
                </shape>
            </item>
            <item android:top="6dp" android:bottom="6dp" android:left="6dp" android:right="6dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#364656" android:endColor="#111A24" />
                    <corners android:radius="8dp" />
                    <stroke android:width="1dp" android:color="#2F4255" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#13202E" android:endColor="#04070B" />
                    <corners android:radius="14dp" />
                    <stroke android:width="1dp" android:color="#33485D" />
                </shape>
            </item>
            <item android:top="3dp" android:bottom="3dp" android:left="3dp" android:right="3dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_active_bottom"
                        android:startColor="@color/control_small_active_top" />
                    <corners android:radius="10dp" />
                    <stroke android:width="1.4dp" android:color="#A3B7CD" />
                </shape>
            </item>
            <item android:top="4.5dp" android:bottom="21dp" android:left="5.5dp" android:right="5.5dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#8AA1BA" android:endColor="#128AA1BA" />
                    <corners android:radius="7dp" />
                </shape>
            </item>
            <item android:top="6dp" android:bottom="6dp" android:left="6dp" android:right="6dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#3A4C5E" android:endColor="#14202B" />
                    <corners android:radius="8dp" />
                    <stroke android:width="1dp" android:color="#304357" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_activated="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#13202E" android:endColor="#04070B" />
                    <corners android:radius="14dp" />
                    <stroke android:width="1dp" android:color="#33485D" />
                </shape>
            </item>
            <item android:top="3dp" android:bottom="3dp" android:left="3dp" android:right="3dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_active_bottom"
                        android:startColor="@color/control_small_active_top" />
                    <corners android:radius="10dp" />
                    <stroke android:width="1.4dp" android:color="#A3B7CD" />
                </shape>
            </item>
            <item android:top="4.5dp" android:bottom="21dp" android:left="5.5dp" android:right="5.5dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#8AA1BA" android:endColor="#128AA1BA" />
                    <corners android:radius="7dp" />
                </shape>
            </item>
            <item android:top="6dp" android:bottom="6dp" android:left="6dp" android:right="6dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#3A4C5E" android:endColor="#14202B" />
                    <corners android:radius="8dp" />
                    <stroke android:width="1dp" android:color="#304357" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#12202E" android:endColor="#04070B" />
                    <corners android:radius="14dp" />
                    <stroke android:width="1dp" android:color="#2E4154" />
                </shape>
            </item>
            <item android:top="3dp" android:bottom="3dp" android:left="3dp" android:right="3dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_bottom"
                        android:startColor="@color/control_small_top" />
                    <corners android:radius="10dp" />
                    <stroke android:width="1.35dp" android:color="#90A4BA" />
                </shape>
            </item>
            <item android:top="4.5dp" android:bottom="21dp" android:left="5.5dp" android:right="5.5dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#89A3BC" android:endColor="#1289A3BC" />
                    <corners android:radius="7dp" />
                </shape>
            </item>
            <item android:top="6dp" android:bottom="6dp" android:left="6dp" android:right="6dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#344656" android:endColor="#111D28" />
                    <corners android:radius="8dp" />
                    <stroke android:width="1dp" android:color="#2B3E51" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
