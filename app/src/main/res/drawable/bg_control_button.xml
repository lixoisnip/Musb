<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_small_shell_disabled_top"
                        android:endColor="@color/control_small_shell_disabled_bottom" />
                    <corners android:radius="14dp" />
                    <stroke android:width="1dp" android:color="@color/control_small_shell_stroke_disabled" />
                </shape>
            </item>
            <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="3dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_small_disabled_top"
                        android:endColor="@color/control_small_disabled_bottom" />
                    <corners android:radius="11dp" />
                    <stroke android:width="0.8dp" android:color="@color/control_small_stroke_disabled" />
                </shape>
            </item>
            <item android:left="8dp" android:top="6dp" android:right="8dp" android:bottom="46dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_small_highlight_disabled"
                        android:endColor="@android:color/transparent" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_small_shell_pressed_top"
                        android:endColor="@color/control_small_shell_pressed_bottom" />
                    <corners android:radius="14dp" />
                    <stroke android:width="1dp" android:color="@color/control_small_shell_stroke_pressed" />
                </shape>
            </item>
            <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="3dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_small_pressed_top"
                        android:endColor="@color/control_small_pressed_bottom" />
                    <corners android:radius="11dp" />
                    <stroke android:width="0.8dp" android:color="@color/control_small_stroke_pressed" />
                </shape>
            </item>
            <item android:left="8dp" android:top="6dp" android:right="8dp" android:bottom="46dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_small_highlight_pressed"
                        android:endColor="@android:color/transparent" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_small_shell_active_top"
                        android:endColor="@color/control_small_shell_active_bottom" />
                    <corners android:radius="14dp" />
                    <stroke android:width="1dp" android:color="@color/control_small_shell_stroke_active" />
                </shape>
            </item>
            <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="3dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_small_active_top"
                        android:endColor="@color/control_small_active_bottom" />
                    <corners android:radius="11dp" />
                    <stroke android:width="0.8dp" android:color="@color/control_small_stroke_active" />
                </shape>
            </item>
            <item android:left="8dp" android:top="6dp" android:right="8dp" android:bottom="46dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_small_highlight_active"
                        android:endColor="@android:color/transparent" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_activated="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_small_shell_active_top"
                        android:endColor="@color/control_small_shell_active_bottom" />
                    <corners android:radius="14dp" />
                    <stroke android:width="1dp" android:color="@color/control_small_shell_stroke_active" />
                </shape>
            </item>
            <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="3dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_small_active_top"
                        android:endColor="@color/control_small_active_bottom" />
                    <corners android:radius="11dp" />
                    <stroke android:width="0.8dp" android:color="@color/control_small_stroke_active" />
                </shape>
            </item>
            <item android:left="8dp" android:top="6dp" android:right="8dp" android:bottom="46dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_small_highlight_active"
                        android:endColor="@android:color/transparent" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_small_shell_top"
                        android:endColor="@color/control_small_shell_bottom" />
                    <corners android:radius="14dp" />
                    <stroke android:width="1dp" android:color="@color/control_small_shell_stroke" />
                </shape>
            </item>
            <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="3dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_small_top"
                        android:endColor="@color/control_small_bottom" />
                    <corners android:radius="11dp" />
                    <stroke android:width="0.8dp" android:color="@color/control_small_stroke" />
                </shape>
            </item>
            <item android:left="8dp" android:top="6dp" android:right="8dp" android:bottom="46dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/control_small_highlight"
                        android:endColor="@android:color/transparent" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
