<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/control_small_shell_disabled" />
                    <corners android:radius="15dp" />
                </shape>
            </item>
            <item android:top="1.5dp" android:bottom="1.5dp" android:left="1.5dp" android:right="1.5dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_disabled_bottom"
                        android:startColor="@color/control_small_disabled_top" />
                    <corners android:radius="13.5dp" />
                    <stroke android:width="1dp" android:color="#29313B" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/control_small_shell_pressed" />
                    <corners android:radius="15dp" />
                </shape>
            </item>
            <item android:top="1.5dp" android:bottom="1.5dp" android:left="1.5dp" android:right="1.5dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_pressed_bottom"
                        android:startColor="@color/control_small_pressed_top" />
                    <corners android:radius="13.5dp" />
                    <stroke android:width="1.1dp" android:color="@color/control_small_stroke_active" />
                </shape>
            </item>
            <item android:top="3dp" android:bottom="3dp" android:left="3dp" android:right="3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="11.5dp" />
                    <stroke android:width="1dp" android:color="@color/control_small_stroke_inner" />
                </shape>
            </item>
            <item android:top="6dp" android:bottom="6dp" android:left="6dp" android:right="6dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#1A2532" android:endColor="#101924" />
                    <corners android:radius="8.5dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/control_small_shell" />
                    <corners android:radius="15dp" />
                </shape>
            </item>
            <item android:top="1.5dp" android:bottom="1.5dp" android:left="1.5dp" android:right="1.5dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_active_bottom"
                        android:startColor="@color/control_small_active_top" />
                    <corners android:radius="13.5dp" />
                    <stroke android:width="1.1dp" android:color="@color/control_small_stroke_active" />
                </shape>
            </item>
            <item android:top="3dp" android:bottom="3dp" android:left="3dp" android:right="3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="11.5dp" />
                    <stroke android:width="1dp" android:color="@color/control_small_stroke_inner" />
                </shape>
            </item>
            <item android:top="6dp" android:bottom="6dp" android:left="6dp" android:right="6dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#25313F" android:endColor="#141E2A" />
                    <corners android:radius="8.5dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_activated="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/control_small_shell" />
                    <corners android:radius="15dp" />
                </shape>
            </item>
            <item android:top="1.5dp" android:bottom="1.5dp" android:left="1.5dp" android:right="1.5dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_active_bottom"
                        android:startColor="@color/control_small_active_top" />
                    <corners android:radius="13.5dp" />
                    <stroke android:width="1.1dp" android:color="@color/control_small_stroke_active" />
                </shape>
            </item>
            <item android:top="3dp" android:bottom="3dp" android:left="3dp" android:right="3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="11.5dp" />
                    <stroke android:width="1dp" android:color="@color/control_small_stroke_inner" />
                </shape>
            </item>
            <item android:top="6dp" android:bottom="6dp" android:left="6dp" android:right="6dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#25313F" android:endColor="#141E2A" />
                    <corners android:radius="8.5dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/control_small_shell" />
                    <corners android:radius="15dp" />
                </shape>
            </item>
            <item android:top="1.5dp" android:bottom="1.5dp" android:left="1.5dp" android:right="1.5dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_bottom"
                        android:startColor="@color/control_small_top" />
                    <corners android:radius="13.5dp" />
                    <stroke android:width="1.1dp" android:color="@color/control_small_stroke" />
                </shape>
            </item>
            <item android:top="3dp" android:bottom="3dp" android:left="3dp" android:right="3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="11.5dp" />
                    <stroke android:width="1dp" android:color="@color/control_small_stroke_inner" />
                </shape>
            </item>
            <item android:top="6dp" android:bottom="6dp" android:left="6dp" android:right="6dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="270" android:startColor="#222E3A" android:endColor="#121B26" />
                    <corners android:radius="8.5dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
