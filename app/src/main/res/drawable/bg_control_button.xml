<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/control_small_shell_disabled" />
                    <corners android:radius="17dp" />
                </shape>
            </item>
            <item android:top="1dp" android:bottom="1dp" android:left="1dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_disabled_bottom"
                        android:startColor="@color/control_small_disabled_top" />
                    <corners android:radius="16dp" />
                    <stroke android:width="1dp" android:color="#2A3340" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/control_small_shell_pressed" />
                    <corners android:radius="17dp" />
                </shape>
            </item>
            <item android:top="1dp" android:bottom="1dp" android:left="1dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_pressed_bottom"
                        android:startColor="@color/control_small_pressed_top" />
                    <corners android:radius="16dp" />
                    <stroke android:width="1dp" android:color="@color/control_small_stroke_active" />
                </shape>
            </item>
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="15dp" />
                    <stroke android:width="1dp" android:color="@color/control_small_stroke_inner" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/control_small_shell" />
                    <corners android:radius="17dp" />
                </shape>
            </item>
            <item android:top="1dp" android:bottom="1dp" android:left="1dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_active_bottom"
                        android:startColor="@color/control_small_active_top" />
                    <corners android:radius="16dp" />
                    <stroke android:width="1dp" android:color="@color/control_small_stroke_active" />
                </shape>
            </item>
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="15dp" />
                    <stroke android:width="1dp" android:color="@color/control_small_stroke_inner" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_activated="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/control_small_shell" />
                    <corners android:radius="17dp" />
                </shape>
            </item>
            <item android:top="1dp" android:bottom="1dp" android:left="1dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_active_bottom"
                        android:startColor="@color/control_small_active_top" />
                    <corners android:radius="16dp" />
                    <stroke android:width="1dp" android:color="@color/control_small_stroke_active" />
                </shape>
            </item>
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="15dp" />
                    <stroke android:width="1dp" android:color="@color/control_small_stroke_inner" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/control_small_shell" />
                    <corners android:radius="17dp" />
                </shape>
            </item>
            <item android:top="1dp" android:bottom="1dp" android:left="1dp" android:right="1dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:endColor="@color/control_small_bottom"
                        android:startColor="@color/control_small_top" />
                    <corners android:radius="16dp" />
                    <stroke android:width="1dp" android:color="@color/control_small_stroke" />
                </shape>
            </item>
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="15dp" />
                    <stroke android:width="1dp" android:color="@color/control_small_stroke_inner" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
