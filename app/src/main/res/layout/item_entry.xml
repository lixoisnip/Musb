<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/entryRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="5dp"
    android:background="@drawable/bg_list_item"
    android:gravity="center_vertical"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="8dp"
    android:paddingEnd="11dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/entryIcon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:gravity="center"
        android:text="📁"
        android:textColor="@color/list_item_meta_text"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/entryName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="11dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/list_item_text"
        android:textSize="14.5sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/entryDuration"
        android:layout_width="50dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:text="--:--"
        android:textColor="@color/list_item_meta_text"
        android:textSize="10sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/playFolderButton"
        android:layout_width="70dp"
        android:layout_height="30dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_folder_chip"
        android:paddingHorizontal="8dp"
        android:text="@string/play_all"
        android:textAllCaps="false"
        android:textColor="@color/text_primary"
        android:textSize="9sp"
        android:visibility="gone" />
</LinearLayout>
