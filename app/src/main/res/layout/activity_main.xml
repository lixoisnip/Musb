<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:paddingStart="10dp"
    android:paddingTop="6dp"
    android:paddingEnd="10dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="34dp"
        android:background="@drawable/bg_top_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@drawable/bg_status_badge"
            android:gravity="center"
            android:text="M"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/pathText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="USB • Music • Rock"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/topSourceText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="end"
            android:maxLines="1"
            android:text="@string/top_source_placeholder"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/clockText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="--:--"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/panelRow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="7dp"
        android:baselineAligned="false"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/controlRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="7dp"
            android:layout_weight="0.95"
            android:background="@drawable/bg_panel_rounded"
            android:orientation="vertical"
            android:paddingStart="11dp"
            android:paddingTop="12dp"
            android:paddingEnd="11dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/folders"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/leftRecycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="6dp" />

            <TextView
                android:id="@+id/leftEmptyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginHorizontal="8dp"
                android:paddingTop="10dp"
                android:text="@string/no_folders_found"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="7dp"
            android:layout_weight="1.35"
            android:background="@drawable/bg_panel_center"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="15dp"
            android:paddingEnd="20dp"
            android:paddingBottom="14dp">

            <FrameLayout
                android:layout_width="236dp"
                android:layout_height="236dp"
                android:background="@drawable/bg_cover_frame"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/coverImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:background="@drawable/bg_cover"
                    android:contentDescription="@string/cover_desc"
                    android:scaleType="centerCrop" />
            </FrameLayout>

            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/no_track"
                android:textColor="@color/text_primary"
                android:textSize="29sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/artistText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/unknown_artist"
                android:textColor="@color/accent_amber"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/albumText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/unknown_album"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_now_playing_footer"
                android:orientation="vertical"
                android:paddingStart="9dp"
                android:paddingTop="4dp"
                android:paddingEnd="9dp"
                android:paddingBottom="5dp">

                <SeekBar
                    android:id="@+id/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="1000"
                    android:minHeight="20dp"
                    android:progress="0"
                    android:progressBackgroundTint="#414A58"
                    android:progressTint="@color/accent_amber"
                    android:thumb="@drawable/bg_seekbar_thumb"
                    android:thumbTint="@color/accent_amber" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/currentTimeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/totalTimeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rightPanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="7dp"
            android:layout_weight="0.95"
            android:background="@drawable/bg_panel_playlist"
            android:orientation="vertical"
            android:paddingStart="11dp"
            android:paddingTop="12dp"
            android:paddingEnd="11dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/files"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rightRecycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="6dp" />

            <TextView
                android:id="@+id/rightEmptyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginHorizontal="8dp"
                android:paddingTop="10dp"
                android:text="@string/no_supported_audio"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_now_playing_footer"
                android:gravity="center"
                android:text="@string/folder_files_footer"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/controlRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_controls_cluster"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toTopOf="@id/bottomInfoBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/prevButton"
                style="@style/ControlButtonSmall"
                android:contentDescription="@string/prev"
                android:src="@drawable/ic_transport_prev"
                android:tint="@color/control_icon_tint_selector" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/seekButton"
                style="@style/ControlButtonSmall"
                android:contentDescription="@string/seek_forward_hint"
                android:src="@drawable/ic_transport_seek"
                android:tint="@color/control_icon_tint_selector" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/browseButton"
                style="@style/ControlButtonSmall"
                android:contentDescription="@string/browse"
                android:src="@drawable/ic_transport_browse"
                android:tint="@color/control_icon_tint_selector" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/shuffleButton"
                style="@style/ControlButtonSmall"
                android:contentDescription="@string/shuffle_label"
                android:src="@drawable/ic_transport_shuffle"
                android:tint="@color/control_icon_tint_selector" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/playPauseButton"
                style="@style/ControlButtonCenter"
                android:contentDescription="@string/play_pause"
                android:src="@drawable/ic_transport_play"
                android:tint="@color/control_icon_tint_selector" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/repeatButton"
                style="@style/ControlButtonSmall"
                android:contentDescription="@string/repeat_label"
                android:src="@drawable/ic_transport_repeat"
                android:tint="@color/control_icon_tint_selector" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/listButton"
                style="@style/ControlButtonSmall"
                android:contentDescription="@string/list_label"
                android:src="@drawable/ic_transport_list"
                android:tint="@color/control_icon_tint_selector" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/commentButton"
                style="@style/ControlButtonSmall"
                android:contentDescription="@string/track_info_title"
                android:src="@drawable/ic_transport_info"
                android:tint="@color/control_icon_tint_selector" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/muteButton"
                style="@style/ControlButtonSmall"
                android:contentDescription="@string/mute"
                android:src="@drawable/ic_transport_volume_on"
                android:tint="@color/control_icon_tint_selector" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/nextButton"
                style="@style/ControlButtonSmall"
                android:contentDescription="@string/next"
                android:src="@drawable/ic_transport_next"
                android:tint="@color/control_icon_tint_selector" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/bottomInfoBar"
        android:layout_width="0dp"
        android:layout_height="28dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/bg_bottom_info"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/usbStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_usb_connected"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/formatInfoText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="MP3 • 320 kbps • 44.1 kHz"
            android:textColor="@color/text_muted"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/deviceBadgeText"
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:background="@drawable/bg_device_badge"
            android:gravity="center"
            android:paddingHorizontal="11dp"
            android:text="TEYES CC3"
            android:textColor="@color/text_primary"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
