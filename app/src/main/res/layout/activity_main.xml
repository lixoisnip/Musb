<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:paddingStart="32dp"
    android:paddingTop="6dp"
    android:paddingEnd="32dp"
    android:paddingBottom="0dp">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="23dp"
        android:background="@drawable/bg_top_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="40dp"
            android:layout_height="20dp"
            android:background="@drawable/bg_status_badge"
            android:gravity="center"
            android:text="LS"
            android:textColor="@color/text_primary"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/pathText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="USB • Music • Rock"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/topSourceText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="end"
            android:maxLines="1"
            android:text="@string/top_source_placeholder"
            android:textColor="@color/text_muted"
            android:textSize="7sp" />

        <TextView
            android:id="@+id/clockText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="--:--"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/panelRow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="18dp"
        android:baselineAligned="false"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/controlRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="27dp"
            android:layout_weight="1.0"
            android:background="@drawable/bg_panel_rounded"
            android:orientation="vertical"
            android:paddingStart="0dp"
            android:paddingTop="0dp"
            android:paddingEnd="0dp"
            android:paddingBottom="0dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="36dp"
                android:paddingTop="24dp"
                android:text="@string/left_panel_title"
                android:textColor="@color/text_primary"
                android:textSize="16.5sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/leftRecycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="20dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="6dp"
                android:paddingHorizontal="0dp" />

            <TextView
                android:id="@+id/leftEmptyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginHorizontal="8dp"
                android:paddingTop="8dp"
                android:alpha="0.88"
                android:text="@string/no_folders_found"
                android:textColor="@color/text_muted"
                android:textSize="5.5sp"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="27dp"
            android:layout_weight="0.99"
            android:background="@drawable/bg_panel_center"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="19dp"
            android:paddingTop="0dp"
            android:paddingEnd="19dp"
            android:paddingBottom="8dp">

            <FrameLayout
                android:layout_width="360dp"
                android:layout_height="305dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_cover_frame"
                android:padding="0dp">

                <ImageView
                    android:id="@+id/coverImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:background="@drawable/bg_cover"
                    android:contentDescription="@string/cover_desc"
                    android:scaleType="centerCrop" />
            </FrameLayout>

            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="118dp"
                android:ellipsize="end"
                android:gravity="center"
                android:textAlignment="center"
                android:maxLines="1"
                android:text="@string/no_track"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/artistText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:ellipsize="end"
                android:gravity="center"
                android:textAlignment="center"
                android:maxLines="1"
                android:text="@string/unknown_artist"
                android:textColor="@color/text_secondary"
                android:textSize="14.5sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/albumText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:ellipsize="end"
                android:gravity="center"
                android:textAlignment="center"
                android:maxLines="1"
                android:text="@string/unknown_album"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:orientation="vertical"
                android:paddingStart="0dp"
                android:paddingTop="0dp"
                android:paddingEnd="0dp"
                android:paddingBottom="0dp">

                <SeekBar
                    android:id="@+id/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="1000"
                    android:minHeight="19dp"
                    android:progress="0"
                    android:progressBackgroundTint="@color/progress_track"
                    android:progressTint="@color/progress_fill"
                    android:thumb="@drawable/bg_seekbar_thumb"
                    android:thumbTint="@color/progress_fill" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="0dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/currentTimeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/totalTimeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rightPanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="27dp"
            android:layout_weight="0.99"
            android:background="@drawable/bg_panel_playlist"
            android:orientation="vertical"
            android:paddingStart="0dp"
            android:paddingTop="0dp"
            android:paddingEnd="0dp"
            android:paddingBottom="0dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/right_panel_title"
                android:textColor="@color/text_primary"
                android:textSize="16.5sp"
                android:paddingStart="36dp"
                android:paddingTop="24dp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rightRecycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="20dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="6dp" />

            <TextView
                android:id="@+id/rightEmptyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginHorizontal="8dp"
                android:paddingTop="8dp"
                android:alpha="0.88"
                android:text="@string/no_supported_audio"
                android:textColor="@color/text_muted"
                android:textSize="5.5sp"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_marginTop="4dp"
                android:background="@android:color/transparent"
                android:gravity="center"
                android:text="@string/folder_explorer_footer"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/controlRow"
        android:layout_width="0dp"
        android:layout_height="224dp"
        android:background="@drawable/bg_controls_cluster"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingHorizontal="0dp"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomInfoBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:baselineAligned="false"
            android:gravity="center"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/prevButton"
                style="@style/ControlButtonSmall"
                android:contentDescription="@string/prev"
                android:src="@drawable/ic_transport_prev"
                android:tint="@color/control_icon_tint_selector" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/seekButton"
                style="@style/ControlButtonSmall"
                android:contentDescription="@string/seek_forward_hint"
                android:src="@drawable/ic_transport_seek"
                android:tint="@color/control_icon_tint_selector" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/browseButton"
                style="@style/ControlButtonSmall"
                android:contentDescription="@string/browse"
                android:src="@drawable/ic_transport_browse"
                android:tint="@color/control_icon_tint_selector" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/playPauseButton"
                style="@style/ControlButtonCenter"
                android:contentDescription="@string/play_pause"
                android:src="@drawable/ic_transport_play"
                android:tint="@color/control_icon_tint_selector" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/shuffleButton"
                style="@style/ControlButtonSmall"
                android:contentDescription="@string/shuffle_label"
                android:src="@drawable/ic_transport_shuffle"
                android:tint="@color/control_icon_tint_selector" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/listButton"
                style="@style/ControlButtonSmall"
                android:contentDescription="@string/list_label"
                android:src="@drawable/ic_transport_list"
                android:tint="@color/control_icon_tint_selector" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/muteButton"
                style="@style/ControlButtonSmall"
                android:contentDescription="@string/mute"
                android:src="@drawable/ic_transport_volume_on"
                android:tint="@color/control_icon_tint_selector" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/repeatButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                android:contentDescription="@string/repeat_label"
                android:src="@drawable/ic_transport_repeat" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/commentButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                android:contentDescription="@string/track_info_title"
                android:src="@drawable/ic_transport_info" />

        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/bottomInfoBar"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="0dp"
        android:background="@drawable/bg_bottom_info"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/usbStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_usb_connected"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/formatInfoText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="MP3 • 320 kbps • 44.1 kHz"
            android:textColor="@color/text_secondary"
            android:textSize="12.5sp" />

        <TextView
            android:id="@+id/deviceBadgeText"
            android:layout_width="212dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_device_badge"
            android:gravity="center"
            android:text="TEYES CC3"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
