<resources>
    <style name="Theme.LadaStylePlayer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        <item name="colorPrimary">@color/accent_amber</item>
        <item name="colorSecondary">@color/accent_amber</item>
    </style>

    <style name="ControlImageButtonBase">
        <item name="android:backgroundTint">@android:color/transparent</item>
        <item name="android:tint">@color/control_icon_tint</item>
        <item name="android:scaleType">center</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="ControlButtonSmall" parent="ControlImageButtonBase">
        <item name="android:layout_width">62dp</item>
        <item name="android:layout_height">62dp</item>
        <item name="android:layout_marginHorizontal">4dp</item>
        <item name="android:background">@drawable/bg_control_button</item>
    </style>

    <style name="ControlButtonCenter" parent="ControlImageButtonBase">
        <item name="android:layout_width">104dp</item>
        <item name="android:layout_height">104dp</item>
        <item name="android:layout_marginHorizontal">14dp</item>
        <item name="android:background">@drawable/bg_control_button_center</item>
        <item name="android:padding">28dp</item>
    </style>
</resources>
