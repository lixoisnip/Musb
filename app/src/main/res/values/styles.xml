<resources>
    <style name="Theme.LadaStylePlayer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        <item name="colorPrimary">@color/accent_graphite</item>
        <item name="colorSecondary">@color/accent_graphite</item>
    </style>

    <style name="ControlImageButtonBase">
        <item name="android:tint">@color/icon_light</item>
        <item name="android:scaleType">fitCenter</item>
        <item name="android:padding">4dp</item>
    </style>

    <style name="ControlButtonSmall" parent="ControlImageButtonBase">
        <item name="android:layout_width">96dp</item>
        <item name="android:layout_height">96dp</item>
        <item name="android:layout_marginHorizontal">22dp</item>
        <item name="android:background">@drawable/bg_control_button</item>
        <item name="android:padding">20dp</item>
        <item name="android:tint">@color/icon_light</item>
        <item name="android:scaleType">fitCenter</item>
    </style>

    <style name="ControlButtonCenter" parent="ControlImageButtonBase">
        <item name="android:layout_width">150dp</item>
        <item name="android:layout_height">110dp</item>
        <item name="android:layout_marginHorizontal">36dp</item>
        <item name="android:background">@drawable/bg_control_button_center</item>
        <item name="android:padding">6dp</item>
        <item name="android:tint">@color/icon_light</item>
        <item name="android:scaleType">fitCenter</item>
    </style>
</resources>
